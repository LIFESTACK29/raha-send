{
    "expo": {
        "name": "mobile",
        "slug": "mobile",
        "scheme": "rahasend",
        "version": "1.0.0",
        "orientation": "portrait",
        "icon": "./assets/icon.png",
        "userInterfaceStyle": "light",
        "newArchEnabled": true,
        "splash": {
            "image": "./assets/splash-icon.png",
            "resizeMode": "contain",
            "backgroundColor": "#ffffff"
        },
        "ios": {
            "supportsTablet": true,
            "bundleIdentifier": "com.nelson404.mobile",
            "infoPlist": {
                "NSMicrophoneUsageDescription": "RahaSend needs access to your microphone so you can talk to the Dissi AI Voice Assistant.",
                "NSSpeechRecognitionUsageDescription": "RahaSend needs speech recognition to transcribe your voice commands for Dissi AI."
            }
        },
        "android": {
            "adaptiveIcon": {
                "foregroundImage": "./assets/adaptive-icon.png",
                "backgroundColor": "#ffffff"
            },
            "edgeToEdgeEnabled": true,
            "predictiveBackGestureEnabled": false,
            "package": "com.nelson404.mobile",
            "permissions": ["android.permission.RECORD_AUDIO"]
        },
        "web": {
            "favicon": "./assets/favicon.png"
        },
        "plugins": ["expo-font", "expo-secure-store", "expo-web-browser"]
    }
}
